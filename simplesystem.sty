% Automatic List

\int_new:N \g__beta_Automatic_List_int
\int_set:Nn \g__beta_Automatic_List_int {0}
\cs_new:Nn \trans_auto_list:N {
    \int_set:Nn \g___list_num_int {0}
    \tl_replace_all:Nnn #1 {~+~} {
        \int_incr:N \g___list_num_int
        \par \noindent \textbf {\int_use:N \g___list_num_int.}~
    }
    \tl_replace_all:Nnn #1 {~-~} {
        \par \noindent \textbf {\textbullet} \,
    }
}

