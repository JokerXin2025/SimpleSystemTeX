% Section Link

\NewDocumentCommand \seclink {m d()} {
    \seq_if_in:NeTF \g__register_seq {./#1} {
        \group_begin:
        \IfValueT {#2} {
            \tl_set:Nn \l__linktext_tl {#2}   % [provide] @linktext
        }
        \exp_args:Ne \__parse_path:nn {#1} {target}   % [provide] @targetsection, @target(...)group
        \tl_set:Nn \l__targetsectionpath_tl {#1}   % [provide] @targetsectionpath
        \tl_set:Nn \l__targetsectionpage_tl {\pageref*{./#1}}   % [provide] @targetsectionpage
        \prop_get:NeN \g__sectionname_prop {#1} \l__targetsectionname_tl   % [provide] @targetsectionname
        \prop_get:NeN \g__sectionparameter_prop {#1} \l__targetsectionparameter_tl   % [provide] @targetsectionparameter
        \hyperref [./#1] {{\g__SectionLink_format_tl}}
        \group_end:
    } {
        \msg_warning:nne {SimpleSystemTeX} {Section Not Found} {#1}
    }
}

% Group Link

\NewDocumentCommand \grplink {m d()} {
    \seq_if_in:NeTF \g__register_seq {./#1} {
        \group_begin:
        \IfValueT {#2} {
            \tl_set:Nn \l__linktext_tl {#2}   % [provide] @linktext
        }
        \exp_args:Ne \__parse_path:nn {#1.groupkeep} {target}   % [provide] @target(...)group
        \hyperref [./#1] {{\g__GroupLink_format_tl}}
        \group_end:
    } {
        \msg_warning:nne {SimpleSystemTeX} {Group Index Not Found} {#1}
    }
}

% Block Link

\NewDocumentCommand \blclink {m d()} {
    \seq_if_in:NeTF \g__last_register_seq {#1} {
        \group_begin:
        \IfValueT {#2} {
            \tl_set:Nn \l__linktext_tl {#2}   % [provide] @linktext
        }
        \tl_set:Nn \l__targetblock_tl {#1}
        \seq_if_in:NeT \g__register_seq {#1} {
            \prop_get:NeN \g__blockname_prop {#1} \l__targetblockname_tl   % [provide] @targetblockname
            \prop_get:NeN \g__blockparameter_prop {#1} \l__targetblockparameter_tl   % [provide] @targetblockparameter
            \prop_get:NeN \g__blockcontent_prop {#1} \l__targetblockcontent_tl   % [provide] @targetblockcontent
        }
        \hyperref [#1] {{\g__BlockLink_format_tl}}
        \group_end:
    } {
        \msg_warning:nne {SimpleSystemTeX} {Block Not Found} {#1}
    }
}

