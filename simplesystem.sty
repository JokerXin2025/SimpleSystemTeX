\NewDocumentCommand \SetSectionPath {m} {
    \str_gset:Nn \g__path_prefix_str {#1}
}
\NewDocumentCommand \ImportSection {m d() d<>} {
    \group_begin:
    \seq_if_in:NeTF \g__register_seq {./#1} {
        \msg_error:nne {SimpleSystemTeX} {Section Repeated} {#1}
    } {
        \seq_gput_right:Ne \g__register_seq {./#1}
    }
    \seq_set_split:Nne \l_tmpa_seq {/} {#1}
    \seq_pop_right:NN \l_tmpa_seq \l_tmpa_tl
    \IfValueTF {#2} {
        \prop_gput:Nen \g__sectionname_prop {#1} {#2}
    } {
        \prop_gput:NeV \g__sectionname_prop {#1} \l_tmpa_tl   % [set] @sectionname
    }
    \prop_gput:Nen \g__sectionparameter_prop {#1} {#3}   % [set] @sectionparameter
    \tl_gput_right:Ne \g__task_list_tl {\exp_not:N \Section {{#1}}}
    \group_end:
}
\NewDocumentCommand \MakeCatalog {} {
    \tl_put_right:Nn \g__task_list_tl {\Catalog {}}
}
\NewDocumentCommand \CatalogPart {m} {
    \tl_put_right:Nn \g__task_list_tl {\CatalogPart {{#1}}}
}
\NewDocumentCommand \CatalogCommand {m} {
    \tl_put_right:Nn \g__task_list_tl {\CatalogCommand {{#1}}}
}
\NewDocumentCommand \TextCommand {m} {
    \tl_put_right:Nn \g__task_list_tl {\TextCommand {{#1}}}
}

% --------------------------------------------------
% | Core Tools |
% --------------------------------------------------

\cs_new_protected:Nn \__restore_register_item:n {
    \seq_gput_right:Nn \g__last_register_seq {#1}
}
\cs_new_protected:Nn \__make_prop_loop:Nnn {
    \quark_if_recursion_tail_stop:n {#2}
    \prop_put:Nnn #1 {#2} {#3}
    \__make_prop_loop:Nnn #1
}
\cs_new_protected:Nn \__execute_loop:Nnn {
    \quark_if_recursion_tail_stop:n {#2}
    \prop_get:NnNT #1 {#2} \g___loop_command_tl {
        \g___loop_command_tl #3
    }
    \__execute_loop:Nnn #1
}
\cs_new_protected:Nn \__execute_rule:Nn {
    \prop_clear:N \g___rule_prop
    \__make_prop_loop:Nnn \g___rule_prop #2 \q_recursion_tail \q_recursion_tail \q_recursion_stop
    \tl_set_eq:NN \g___task_list_tl #1
    \tl_put_right:Nn \g___task_list_tl {\q_recursion_tail \q_recursion_tail \q_recursion_stop}
    \exp_after:wN \__execute_loop:Nnn \exp_after:wN \g___rule_prop \g___task_list_tl
}
\cs_new:Nn \__parse_path:nn {
    \clist_map_inline:nn {group, subgroup, subsubgroup, subsubsubgroup} {
        \exp_args:Nc \tl_clear:N {l__#2##1_tl}
    }
    \seq_set_split:Nnn \l__path_seq {/} {#1}
    \exp_args:NNc \seq_pop_right:NN \l__path_seq {l__#2section_tl}
    \seq_map_indexed_inline:Nn \l__path_seq {
        \int_case:nn {##1} {
            {1} {\exp_args:Nc \tl_set:Nn {l__#2group_tl} {##2}}
            {2} {\exp_args:Nc \tl_set:Nn {l__#2subgroup_tl} {##2}}
            {3} {\exp_args:Nc \tl_set:Nn {l__#2subsubgroup_tl} {##2}}
            {4} {\exp_args:Nc \tl_set:Nn {l__#2subsubsubgroup_tl} {##2}}
        }
    }
}

\AtBeginDocument {
    \ExplSyntaxOn
    \file_if_exist:nTF {\c_sys_jobname_str.sst} {
        \file_input:n {\c_sys_jobname_str.sst}
    } {
        \msg_warning:nne {SimpleSystemTeX} {File Not Found} {\c_sys_jobname_str.sst}
    }
    \ExplSyntaxOff
}
\AtEndDocument {
    \__execute_rule:Nn \g__task_list_tl {
        \Section \__print_section:n
        \Catalog \__print_catalog:
        \TextCommand \use:n
    }
    \iow_open:Nn \g__register_iow {\c_sys_jobname_str.sst}
    \seq_map_inline:Nn \g__register_seq {
        \iow_now:Nn \g__register_iow {
            \__restore_register_item:n {#1}
        }
    }
    \iow_close:N \g__register_iow
}

% --------------------------------------------------
% | Section |
% --------------------------------------------------

\cs_new:Nn \__print_section:n {
    \phantomsection \label{./#1}
    \group_begin:
    \__parse_path:nn {#1} {}   % [provide] @section, @(...)group
    \tl_set:Nn \l__sectionpath_tl {#1}   % [provide] @sectionpath
    \tl_set:Nn \l__sectionpage_tl {\pageref*{./#1}}   % [provide] @sectionpage
    \prop_get:NnN \g__sectionname_prop {#1} \l__sectionname_tl   % [provide] @sectionname
    \prop_get:NnN \g__sectionparameter_prop {#1} \l__sectionparameter_tl   % [provide] @sectionparameter
    {\g__SectionHeading_format_tl}
    \file_if_exist:nTF {\g__path_prefix_str #1.tex} {
        \file_input:n {\g__path_prefix_str #1.tex}
    } {
        \msg_warning:nne {SimpleSystemTeX} {File Not Found} {#1.tex}
    }
    \group_end:
}

% --------------------------------------------------
% | Catalog |
% --------------------------------------------------

\cs_new:Nn \__process_catalog_part:n {
    \tl_set:Nn \l__part_tl {#1}   % [provide] @part
    {\g__CatalogPartTitle_format_tl}
}
\cs_new:Nn \__print_catalog_section:n {
    \group_begin:
    \exp_args:Ne \__parse_path:nn {#1} {catalog}   % [provide] @catalogsection, @catalog(...)group
    \tl_set:Nn \l__catalogsectionpath_tl {#1}   % [provide] @catalogsectionpath
    \tl_set:Nn \l__catalogsectionpage_tl {\pageref*{./#1}}   % [provide] @catalogsectionpage
    \prop_get:NnN \g__sectionname_prop {#1} \l__catalogsectionname_tl   % [provide] @catalogsectionname
    \prop_get:NnN \g__sectionparameter_prop {#1} \l__catalogsectionparameter_tl   % [provide] @catalogsectionparameter
    {\g__CatalogSection_format_tl}
    \group_end:
}

\cs_new:Nn \__print_catalog: {
    \group_begin:
    {\g__CatalogTitle_format_tl}
    \__execute_rule:Nn \g__task_list_tl {
        \Section \__print_catalog_section:n
        \CatalogPart \__process_catalog_part:n
        \CatalogCommand \use:n
    }
    \group_end:
}

% --------------------------------------------------
% | Index |
% --------------------------------------------------

\cs_new:Nn \__process_group_index_section:nn {
    \tl_set:Nn \g___index_tmpa_tl {\q_prefix_mark #2}
    \tl_replace_once:Nnn \g___index_tmpa_tl {\q_prefix_mark #1} {}
    \tl_if_in:NnF \g___index_tmpa_tl {\q_prefix_mark} {
        \seq_set_split:NnV \g___index_tmpa_seq {/} \g___index_tmpa_tl
        \int_compare:nTF {\seq_count:N \g___index_tmpa_seq == 1} {
            \group_begin:
            \seq_set_split:Nnn \g___index_tmpa_seq {/} {#2}
            \seq_pop_right:NN \g___index_tmpa_seq \l__indexsection_tl   % [provide] @indexsection
            \tl_set:Nn \l__indexsectionpath_tl {#2}   % [provide] @indexsectionpath
            \tl_set:Nn \l__indexsectionpage_tl {\pageref*{./#2}}   % [provide] @indexsectionpage
            \prop_get:NnN \g__sectionname_prop {#2} \l__indexsectionname_tl   % [provide] @indexsectionname
            \prop_get:NnN \g__sectionparameter_prop {#2} \l__indexsectionparameter_tl   % [provide] @indexsectionparameter
            {\g__IndexSection_format_tl}
            \group_end:
        } {
            \seq_if_in:NeF \l__nextgroup_seq {
                \exp_not:n {#1} \seq_item:Nn \g___index_tmpa_seq {1} /
            } {
                \seq_put_right:Ne \l__nextgroup_seq {
                    \exp_not:n {#1} \seq_item:Nn \g___index_tmpa_seq {1} /
                }
            }
        }
    }
}

% Group Index

\NewDocumentCommand \MakeGroupIndex {m d<>} {
    \group_begin:
    \seq_clear:N \l__nextgroup_seq
    \exp_args:Ne \__parse_path:nn {#1.groupkeep} {index}   % [provide] @index(...)group
    \IfValueT {#2} {
        \tl_set:Nn \l__indexparameter_tl {#2}   % [provide] @indexparameter
    }
    \seq_if_in:NeTF \g__register_seq {./#1} {
        \msg_error:nne {SimpleSystemTeX} {Group Index Repeated} {#1}
    } {
        \phantomsection \label{./#1}
        \seq_gput_right:Ne \g__register_seq {./#1}
    }
    \int_case:nn {\seq_count:N \l__path_seq} {
        {0} {
            \msg_error:nne {SimpleSystemTeX} {Illegal Group Path} {#1}
        }
        {1} {{\g__IndexTitle_format_tl}}
        {2} {{\g__IndexSubtitle_format_tl}}
        {3} {{\g__IndexSubsubtitle_format_tl}}
        {4} {{\g__IndexSubsubsubtitle_format_tl}}
    }
    \exp_args:NNe \__execute_rule:Nn \g__task_list_tl {
        \exp_not:N \Section {\exp_not:N \__process_group_index_section:nn {#1}}
    }
    \seq_map_inline:Nn \l__nextgroup_seq {
        \MakeGroupIndex {##1}
    }
    \group_end:
}

% --------------------------------------------------
% | Block |
% --------------------------------------------------

\NewDocumentCommand \NewBlockType {s m} {
    \tl_new:c {g__#2_format_tl}
    \exp_args:Nc \NewDocumentCommand {#2} {m d() d<> +m} {
        \group_begin:
        \tl_set:Nn \l__block_tl {##1}   % [provide] @block
        \IfValueTF {##2} {
            \tl_set:Nn \l__blockname_tl {##2}   % [provide] @blockname
        } {
            \tl_set:Nn \l__blockname_tl {##1}
        }
        \IfValueT {##3} {
            \tl_set:Nn \l__blockparameter_tl {##3}   % [provide] @blockparameter
        }
        \tl_set:Nn \l__blockcontent_tl {##4}   % [provide] @blockcontent
        \int_compare:nNnT {\g__beta_Automatic_List_int} = {1} {
            \trans_auto_list:N \l__blockcontent_tl
        }
        \IfBooleanF {#1} {
            \seq_if_in:NnTF \g__register_seq {##1} {
                \msg_error:nne {SimpleSystemTeX} {Block Occupied} {##1}
            } {
                \phantomsection \label{##1}
                \seq_gput_right:Nn \g__register_seq {##1}
            }
            \prop_gput:NnV \g__blockname_prop {##1} \l__blockname_tl   % [set] @blockname
            \prop_gput:Nnn \g__blockparameter_prop {##1} {##3}   % [set] @blockparameter
            \prop_gput:NnV \g__blockcontent_prop {##1} \l__blockcontent_tl   % [set] @blockcontent
        }
        \tl_use:c {g__#2_format_tl}
        \group_end:
    }
}

