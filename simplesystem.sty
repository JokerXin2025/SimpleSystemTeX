\NewDocumentCommand \FormatSetting {m +m} {
    \tl_gset:cn {g__#1_format_tl} {#2}
    \exp_args:Nnnc \regex_replace_all:nnN
    {@([a-zA-Z]+)} {\c{l__\1_tl}} {g__#1_format_tl}
    \exp_args:Nnnc \regex_replace_all:nnN
    {\#ifempty} {\c{tl_if_empty:NTF}} {g__#1_format_tl}
    \exp_args:Nnnc \regex_replace_all:nnN
    {\#ifis} {\c{str_if_eq:VnTF}} {g__#1_format_tl}
    \exp_args:Nnnc \regex_replace_all:nnN
    {\#ifequal} {\c{str_if_eq:VVTF}} {g__#1_format_tl}
}

% Default Value

\FormatSetting {CatalogTitle} {
    \bfseries\LARGE
    \begin{center}\textbf{Content}\end{center}
    \bigskip
}
\FormatSetting {CatalogPartTitle} {
    \bfseries\Large
    \par\bigskip\noindent
    @part
    \par\medskip
}
\FormatSetting {CatalogSection} {
    \bfseries
    \par\noindent
    #ifempty @catalogsubgroup {
        \seclink {@catalogsectionpath}
        (\!{\footnotesize @cataloggroup}\:|\: @catalogsectionname\cftdotfill{\cftnodots}\textbf{@catalogsectionpage})
    } {
        #ifequal @catalogsubgroup @catalogsectionname {
            \seclink{@catalogsectionpath}
            (\!{\footnotesize @cataloggroup}\; @catalogsubgroup\cftdotfill{\cftnodots}\textbf{@catalogsectionpage})
        } {
            \seclink{@catalogsectionpath}
            (\!{\footnotesize @cataloggroup}\; @catalogsubgroup\:|\: @catalogsectionname\cftdotfill{\cftnodots}\textbf{@catalogsectionpage})
        }
    }
    \par
}
\FormatSetting {IndexTitle} {
    \bfseries
    \noindent
    {\huge @indexgroup}\ {\Large\ @indexparameter}
    \par\bigskip
}
\FormatSetting {IndexSubtitle} {
    \bfseries
    \par\bigskip\noindent
    \grplink {@indexgroup/@indexsubgroup/}
    ({\normalsize @indexgroup}\ {\Large @indexsubgroup})
    \par\smallskip
}
\FormatSetting {IndexSubsubtitle} {
    \bfseries
    \par\medskip\noindent
    \grplink {@indexgroup/@indexsubgroup/@indexsubsubgroup/}
    (\large @indexsubsubgroup)
    \par
}
\FormatSetting {IndexSection} {
    \bfseries\par\noindent
    #ifempty @indexsubgroup {
        \seclink {@indexsectionpath}
        ({\footnotesize @indexgroup}\:|\: @indexsectionname\cftdotfill{\cftnodots}\textbf{@indexsectionpage})
    } {
        #ifequal @indexsubgroup @indexsectionname {
            \seclink{@indexsectionpath}
            ({\footnotesize @indexgroup}\; @indexsubgroup\cftdotfill{\cftnodots}\textbf{@indexsectionpage})
        } {
            \seclink{@indexsectionpath}
            ({\footnotesize @indexgroup}\; @indexsubgroup\:|\: @indexsectionname\cftdotfill{\cftnodots}\textbf{@indexsectionpage})
        }
    }
}
\FormatSetting {SectionHeading} {
    \bfseries
    \noindent
    #ifempty @subgroup {
        {\Large @group}{\huge\;|\; @sectionname}
    } {
        #ifequal @subgroup @sectionname {
            {\Large @group}\;\;{\huge @subgroup}
        } {
            {\Large @group}\;\;{\huge @subgroup\;|\; @sectionname}
        }
    }
    \par\bigskip
}
\FormatSetting {SectionLink} {
    \bfseries
    #ifempty @linktext {
        #ifempty @targetsubgroup {
            \,{\footnotesize @targetgroup}\:|\: @targetsectionname\,
        } {
            \,{\footnotesize @targetgroup}\; @targetsubgroup\:|\: @targetsectionname\,
        }
    } {
        \, @linktext\,
    }
}
\FormatSetting {GroupLink} {
    \bfseries
    #ifempty @linktext {
        #ifempty @targetsubgroup {
            \, @targetgroup\,
        } {
            \,{\footnotesize @targetgroup}\; @targetsubgroup\,
        }
    } {
        \, @linktext\,
    }
}
\FormatSetting {BlockLink} {
    \bfseries
    #ifempty @linktext {
        \, @targetblockname\,
    } {
        \, @linktext\,
    }
}

